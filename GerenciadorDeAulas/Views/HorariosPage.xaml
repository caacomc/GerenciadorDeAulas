<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GerenciadorDeAulas.Views.HorariosPage"
             Title="HorariosPage">
    <StackLayout Padding="10">

        <Label Text="Meus Horários"
               FontSize="22"
               FontAttributes="Bold"
               HorizontalOptions="Center"/>

        <CollectionView x:Name="gradeHorarios">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Frame Padding="10"
                           Margin="5"
                           CornerRadius="10"
                           HasShadow="True">

                        <StackLayout>
                            <Label Text="{Binding HorarioTexto}"
                                   FontSize="18"
                                   FontAttributes="Bold"/>

                            <Label Text="{Binding Disciplina}" />

                            <Label Text="{Binding Status}"
                                   TextColor="Gray"/>
                        </StackLayout>

                    </Frame>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </StackLayout>
</ContentPage>