<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GerenciadorDeAulas.Views.GerenciarAulasCoordenador"
             BackgroundColor="Beige">

    <ScrollView BackgroundColor="Beige">
        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <Grid BackgroundColor="#B41E14"
              Padding="24,48,24,28">

                <Label Text="Gerenciar Aulas"
                   FontSize="30"
                   FontAttributes="Bold"
                   TextColor="#FDF8F2"/>
            </Grid>

            <VerticalStackLayout Padding="20"
                             Spacing="16">

                <!-- ========================= -->
                <!-- FILTROS -->
                <!-- ========================= -->
                <Frame BackgroundColor="#FDF8F2"
                   BorderColor="#E2D5C3"
                   CornerRadius="16"
                   HasShadow="False"
                   Padding="20">

                    <VerticalStackLayout Spacing="15">

                        <Label Text="FILTROS"
                           FontSize="10"
                           CharacterSpacing="2"
                           FontAttributes="Bold"
                           TextColor="#B41E14"/>

                        <BoxView HeightRequest="1"
                             BackgroundColor="#E2D5C3"/>

                        <Picker x:Name="pickerFiltroProfessor"
                            Title="Professor"
                            TitleColor="#B41E14"
                            TextColor="Black"
                            BackgroundColor="#FAECE8"/>

                        <Picker x:Name="pickerFiltroDisciplina"
                            Title="Disciplina"
                            TitleColor="#B41E14"
                            TextColor="Black"
                            BackgroundColor="#FAECE8"/>

                        <Picker x:Name="pickerFiltroSala"
                            Title="Sala"
                            TitleColor="#B41E14"
                            TextColor="Black"
                            BackgroundColor="#FAECE8"/>

                        <Button Text="Filtrar"
                            BackgroundColor="#B41E14"
                            TextColor="White"
                            CornerRadius="12"
                            HeightRequest="50"
                            Clicked="Filtrar_Clicked"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- ========================= -->
                <!-- GRADE -->
                <!-- ========================= -->
                <Frame BackgroundColor="#FDF8F2"
                   BorderColor="#E2D5C3"
                   CornerRadius="16"
                   HasShadow="False"
                   Padding="20">

                    <VerticalStackLayout Spacing="15">

                        <Label Text="GRADE SEMANAL"
                           FontSize="10"
                           CharacterSpacing="2"
                           FontAttributes="Bold"
                           TextColor="#B41E14"/>

                        <BoxView HeightRequest="1"
                             BackgroundColor="#E2D5C3"/>

                        <ScrollView Orientation="Both"
                                HeightRequest="500">

                            <Grid x:Name="gradeSemanal"
                              HorizontalOptions="Center"
                              VerticalOptions="Center"
                              RowSpacing="2"
                              ColumnSpacing="2"
                              BackgroundColor="#E2D5C3"/>
                        </ScrollView>

                    </VerticalStackLayout>
                </Frame>

                <!-- ========================= -->
                <!-- FORMULÁRIO -->
                <!-- ========================= -->
                <Frame BackgroundColor="#FDF8F2"
                   BorderColor="#E2D5C3"
                   CornerRadius="16"
                   HasShadow="False"
                   Padding="20">

                    <VerticalStackLayout Spacing="15">

                        <Label Text="EDITAR AULA"
                           FontSize="10"
                           CharacterSpacing="2"
                           FontAttributes="Bold"
                           TextColor="#B41E14"/>

                        <BoxView HeightRequest="1"
                             BackgroundColor="#E2D5C3"/>

                        <Picker x:Name="pickerProfessor"
                            Title="Professor"
                            TitleColor="#B41E14"
                            TextColor="Black"
                            BackgroundColor="#FAECE8"/>

                        <Picker x:Name="pickerDisciplina"
                            Title="Disciplina"
                            TitleColor="#B41E14"
                            TextColor="Black"
                            BackgroundColor="#FAECE8"/>

                    </VerticalStackLayout>
                </Frame>

                <!-- ========================= -->
                <!-- BOTÕES -->
                <!-- ========================= -->
                <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="12">

                    <Button Grid.Column="0"
                        Text="Salvar Aula"
                        BackgroundColor="#B41E14"
                        TextColor="White"
                        CornerRadius="12"
                        HeightRequest="55"
                        Clicked="SalvarAula_Clicked"/>

                    <Button Grid.Column="1"
                        Text="Remover Aula"
                        BackgroundColor="#FAECE8"
                        TextColor="#B41E14"
                        BorderColor="#B41E14"
                        BorderWidth="1.5"
                        CornerRadius="12"
                        HeightRequest="55"
                        Clicked="RemoverAula_Clicked"/>

                </Grid>

                <!-- Rodapé -->
                <BoxView HeightRequest="1"
                     Margin="0,10"
                     BackgroundColor="#D9CABB"/>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>