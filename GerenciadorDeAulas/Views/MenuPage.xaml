<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GerenciadorDeAulas.Views.MenuPage">
    <Grid>
        <Border Margin="10" StrokeShape="RoundRectangle 20"
                HorizontalOptions="Fill" VerticalOptions="Fill">
            <Grid ColumnDefinitions="75*, 25*" RowDefinitions="*" ColumnSpacing="10" Margin="10" >
                <Border Grid.Column="0" Padding="10" StrokeShape="RoundRectangle 20"
                        VerticalOptions="Fill" HorizontalOptions="Fill">
                    <CollectionView x:Name="lst_dias" >
                        <CollectionView.Header>
                            <Label Text="Lista de Dias" FontSize="30"/>
                        </CollectionView.Header>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <SwipeView>
                                    <SwipeView.RightItems>
                                        <SwipeItems Mode="Reveal">
                                            <SwipeItem Text="Ver" BackgroundColor="Red" Invoked="SwipeItem_Invoked"/>


                                        </SwipeItems>
                                    </SwipeView.RightItems>
                                    <Grid Padding="10">
                                        <Label Text="{Binding .}" FontSize="20"/>
                                    </Grid>
                                </SwipeView>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>
                <Border StrokeShape="RoundRectangle 20" Grid.Column="1">
                </Border>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
