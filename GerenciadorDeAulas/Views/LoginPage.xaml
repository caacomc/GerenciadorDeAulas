<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GerenciadorDeAulas.Views.LoginPage"
             BackgroundColor="Beige">

	<Grid ColumnDefinitions="*, 2*">

		<!-- Lado esquerdo -->
		<BoxView Color="Red" />

		<!-- Lado direito (login) -->
		<VerticalStackLayout Grid.Column="1"
                             Padding="40"
                             Spacing="15"
                             VerticalOptions="Center">

			<Label Text="Login"
                   HorizontalOptions="Center"
                   TextColor="Black"
                   FontSize="40"
                   FontAttributes="Bold"/>

			<Label Text="Nome Completo" TextColor="Black" FontAttributes="Bold"/>
            <Entry x:Name="NomeEntry" TextColor ="Black" Placeholder="Digite aqui"/>

			<Label Text="Senha" TextColor="Black" FontAttributes="Bold"/>
            <Entry x:Name="SenhaEntry"  TextColor ="Black" Placeholder="Digite aqui" IsPassword="True"/>

			<Button Text="Entrar"
                    Clicked="OnLoginClicked"
                    BackgroundColor="Red"
                    TextColor="White"
                    Margin="0,20,0,0"/>

		</VerticalStackLayout>

	</Grid>
</ContentPage>